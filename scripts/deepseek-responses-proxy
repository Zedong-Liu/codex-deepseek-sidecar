#!/usr/bin/env python3
"""Minimal Responses-to-DeepSeek proxy for Codex sidecars."""

from __future__ import annotations

import argparse
import json
import os
import sys
import time
import uuid
import urllib.error
import urllib.request
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from typing import Any


DEFAULT_HOST = "127.0.0.1"
DEFAULT_PORT = 12359
DEFAULT_UPSTREAM = "https://api.deepseek.com"
DEFAULT_MAX_BODY = 128 * 1024 * 1024
DEFAULT_TIMEOUT = 900
MODELS = ("deepseek-v4-pro", "deepseek-v4-flash")


def now() -> int:
    return int(time.time())


def json_dumps(value: Any) -> str:
    return json.dumps(value, ensure_ascii=False, separators=(",", ":"))


def content_to_text(content: Any) -> str:
    if content is None:
        return ""
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        parts: list[str] = []
        for part in content:
            if isinstance(part, str):
                parts.append(part)
            elif isinstance(part, dict):
                text = part.get("text")
                if text is None:
                    text = part.get("input_text")
                if text is None:
                    text = part.get("output_text")
                if text is not None:
                    parts.append(str(text))
        return "\n".join(p for p in parts if p)
    return str(content)


def response_input_to_messages(payload: dict[str, Any]) -> list[dict[str, Any]]:
    messages: list[dict[str, Any]] = []
    instructions = payload.get("instructions")
    if instructions:
        messages.append({"role": "system", "content": str(instructions)})

    input_value = payload.get("input", "")
    if isinstance(input_value, str):
        if input_value:
            messages.append({"role": "user", "content": input_value})
        return messages

    if not isinstance(input_value, list):
        messages.append({"role": "user", "content": content_to_text(input_value)})
        return messages

    for item in input_value:
        if isinstance(item, str):
            messages.append({"role": "user", "content": item})
            continue
        if not isinstance(item, dict):
            messages.append({"role": "user", "content": content_to_text(item)})
            continue

        item_type = item.get("type")
        role = item.get("role")
        if item_type == "function_call_output":
            messages.append(
                {
                    "role": "tool",
                    "tool_call_id": item.get("call_id") or item.get("id") or "call_0",
                    "content": content_to_text(item.get("output", "")),
                }
            )
            continue
        if item_type == "function_call":
            call_id = item.get("call_id") or item.get("id") or f"call_{uuid.uuid4().hex}"
            messages.append(
                {
                    "role": "assistant",
                    "content": None,
                    "tool_calls": [
                        {
                            "id": call_id,
                            "type": "function",
                            "function": {
                                "name": item.get("name", ""),
                                "arguments": item.get("arguments", "{}"),
                            },
                        }
                    ],
                }
            )
            continue
        if item_type == "reasoning":
            continue

        if item_type == "message" or role:
            chat_role = role or "user"
            if chat_role == "developer":
                chat_role = "system"
            if chat_role not in ("system", "user", "assistant", "tool"):
                chat_role = "user"
            msg: dict[str, Any] = {
                "role": chat_role,
                "content": content_to_text(item.get("content", "")),
            }
            if chat_role == "tool":
                msg["tool_call_id"] = item.get("tool_call_id") or item.get("call_id") or "call_0"
            messages.append(msg)
            continue

        text = content_to_text(item.get("content", item))
        if text:
            messages.append({"role": "user", "content": text})

    return messages


def response_tools_to_chat_tools(tools: Any) -> list[dict[str, Any]] | None:
    if not isinstance(tools, list) or not tools:
        return None
    chat_tools: list[dict[str, Any]] = []
    for tool in tools:
        if not isinstance(tool, dict):
            continue
        if tool.get("type") != "function":
            continue
        function = tool.get("function")
        if isinstance(function, dict):
            name = function.get("name")
            description = function.get("description", "")
            parameters = function.get("parameters", {})
            strict = function.get("strict", tool.get("strict"))
        else:
            name = tool.get("name")
            description = tool.get("description", "")
            parameters = tool.get("parameters", {})
            strict = tool.get("strict")
        if not name:
            continue
        chat_function: dict[str, Any] = {
            "name": name,
            "description": description,
            "parameters": parameters or {"type": "object", "properties": {}},
        }
        if strict is not None:
            chat_function["strict"] = bool(strict)
        chat_tools.append({"type": "function", "function": chat_function})
    return chat_tools or None


def tool_choice_to_chat(choice: Any) -> Any:
    if choice in (None, "auto", "none", "required"):
        return choice
    if isinstance(choice, dict):
        name = choice.get("name")
        if not name and isinstance(choice.get("function"), dict):
            name = choice["function"].get("name")
        if name:
            return {"type": "function", "function": {"name": name}}
    return "auto"


def responses_to_chat(payload: dict[str, Any]) -> dict[str, Any]:
    chat: dict[str, Any] = {
        "model": payload.get("model", "deepseek-v4-pro"),
        "messages": response_input_to_messages(payload),
        "stream": bool(payload.get("stream", False)),
    }
    passthrough = (
        "temperature",
        "top_p",
        "frequency_penalty",
        "presence_penalty",
        "stop",
        "response_format",
    )
    for key in passthrough:
        if key in payload:
            chat[key] = payload[key]
    if "max_output_tokens" in payload:
        chat["max_tokens"] = payload["max_output_tokens"]
    elif "max_tokens" in payload:
        chat["max_tokens"] = payload["max_tokens"]
    tools = response_tools_to_chat_tools(payload.get("tools"))
    if tools:
        chat["tools"] = tools
        chat["tool_choice"] = tool_choice_to_chat(payload.get("tool_choice", "auto"))
    return chat


def usage_to_responses(usage: dict[str, Any] | None) -> dict[str, int]:
    usage = usage or {}
    input_tokens = int(usage.get("prompt_tokens") or usage.get("input_tokens") or 0)
    output_tokens = int(usage.get("completion_tokens") or usage.get("output_tokens") or 0)
    total_tokens = int(usage.get("total_tokens") or input_tokens + output_tokens)
    return {
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "total_tokens": total_tokens,
    }


def chat_to_response(payload: dict[str, Any], model: str) -> dict[str, Any]:
    choice = (payload.get("choices") or [{}])[0]
    message = choice.get("message") or {}
    output: list[dict[str, Any]] = []
    output_text = message.get("content") or ""
    if output_text:
        output.append(
            {
                "type": "message",
                "id": f"msg_{uuid.uuid4().hex}",
                "status": "completed",
                "role": "assistant",
                "content": [
                    {
                        "type": "output_text",
                        "text": output_text,
                        "annotations": [],
                    }
                ],
            }
        )
    for tool_call in message.get("tool_calls") or []:
        function = tool_call.get("function") or {}
        output.append(
            {
                "type": "function_call",
                "id": f"fc_{uuid.uuid4().hex}",
                "call_id": tool_call.get("id") or f"call_{uuid.uuid4().hex}",
                "name": function.get("name", ""),
                "arguments": function.get("arguments", "{}"),
                "status": "completed",
            }
        )
    return {
        "id": f"resp_{uuid.uuid4().hex}",
        "object": "response",
        "created_at": payload.get("created") or now(),
        "status": "completed",
        "model": payload.get("model") or model,
        "output": output,
        "output_text": output_text,
        "usage": usage_to_responses(payload.get("usage")),
    }


def build_models_response() -> dict[str, Any]:
    return {
        "object": "list",
        "data": [
            {"id": model, "object": "model", "created": 0, "owned_by": "deepseek"}
            for model in MODELS
        ],
    }


class ProxyHandler(BaseHTTPRequestHandler):
    server_version = "deepseek-responses-proxy/0.1"

    def log_message(self, fmt: str, *args: Any) -> None:
        if getattr(self.server, "quiet", False):
            return
        super().log_message(fmt, *args)

    def send_json(self, status: int, payload: dict[str, Any]) -> None:
        data = json_dumps(payload).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def send_error_json(self, status: int, message: str) -> None:
        self.send_json(status, {"error": {"message": message, "type": "proxy_error"}})

    def do_GET(self) -> None:
        path = self.path.split("?", 1)[0]
        if path in ("/health", "/v1/health"):
            self.send_json(200, {"status": "ok"})
        elif path in ("/models", "/v1/models"):
            self.send_json(200, build_models_response())
        else:
            self.send_error_json(404, f"unsupported path: {path}")

    def do_POST(self) -> None:
        path = self.path.split("?", 1)[0]
        try:
            body = self.read_body()
            payload = json.loads(body.decode("utf-8"))
        except Exception as exc:
            self.send_error_json(400, f"invalid JSON request: {exc}")
            return

        if path in ("/responses", "/v1/responses"):
            self.handle_responses(payload)
        elif path in ("/chat/completions", "/v1/chat/completions"):
            self.forward_chat(payload)
        else:
            self.send_error_json(404, f"unsupported path: {path}")

    def read_body(self) -> bytes:
        length = int(self.headers.get("Content-Length") or "0")
        max_body = getattr(self.server, "max_body_bytes", DEFAULT_MAX_BODY)
        if length > max_body:
            raise ValueError(f"request body too large: {length} bytes > {max_body} bytes")
        return self.rfile.read(length)

    def upstream_request(self, payload: dict[str, Any], stream: bool) -> urllib.response.addinfourl:
        api_key = os.environ.get(getattr(self.server, "api_key_env", "DEEPSEEK_API_KEY"))
        if not api_key:
            raise RuntimeError("missing DEEPSEEK_API_KEY")
        upstream = getattr(self.server, "upstream", DEFAULT_UPSTREAM).rstrip("/")
        url = f"{upstream}/chat/completions"
        data = json_dumps(payload).encode("utf-8")
        request = urllib.request.Request(
            url,
            data=data,
            headers={
                "Authorization": f"Bearer {api_key}",
                "Content-Type": "application/json",
                "Accept": "text/event-stream" if stream else "application/json",
            },
            method="POST",
        )
        timeout = getattr(self.server, "timeout", DEFAULT_TIMEOUT)
        return urllib.request.urlopen(request, timeout=timeout)

    def handle_responses(self, payload: dict[str, Any]) -> None:
        chat_payload = responses_to_chat(payload)
        if chat_payload.get("stream"):
            self.forward_streaming_response(chat_payload)
            return
        try:
            upstream = self.upstream_request(chat_payload, stream=False)
            data = upstream.read()
            chat_response = json.loads(data.decode("utf-8"))
            self.send_json(200, chat_to_response(chat_response, chat_payload["model"]))
        except urllib.error.HTTPError as exc:
            self.forward_upstream_error(exc)
        except Exception as exc:
            self.send_error_json(502, str(exc))

    def forward_chat(self, payload: dict[str, Any]) -> None:
        try:
            upstream = self.upstream_request(payload, stream=bool(payload.get("stream")))
            content_type = upstream.headers.get("Content-Type", "application/json")
            self.send_response(upstream.status)
            self.send_header("Content-Type", content_type)
            self.end_headers()
            while True:
                chunk = upstream.read(64 * 1024)
                if not chunk:
                    break
                self.wfile.write(chunk)
                self.wfile.flush()
        except urllib.error.HTTPError as exc:
            self.forward_upstream_error(exc)
        except Exception as exc:
            self.send_error_json(502, str(exc))

    def forward_upstream_error(self, exc: urllib.error.HTTPError) -> None:
        data = exc.read()
        self.send_response(exc.code)
        self.send_header("Content-Type", exc.headers.get("Content-Type", "application/json"))
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def sse(self, event: str, data: dict[str, Any]) -> None:
        packet = f"event: {event}\ndata: {json_dumps(data)}\n\n".encode("utf-8")
        self.wfile.write(packet)
        self.wfile.flush()

    def forward_streaming_response(self, chat_payload: dict[str, Any]) -> None:
        response_id = f"resp_{uuid.uuid4().hex}"
        model = chat_payload["model"]
        try:
            upstream = self.upstream_request(chat_payload, stream=True)
        except urllib.error.HTTPError as exc:
            self.forward_upstream_error(exc)
            return
        except Exception as exc:
            self.send_error_json(502, str(exc))
            return

        self.send_response(200)
        self.send_header("Content-Type", "text/event-stream; charset=utf-8")
        self.send_header("Cache-Control", "no-cache")
        self.end_headers()

        output_index = 0
        next_output_index = 0
        text_started = False
        text = ""
        tool_indexes: dict[int, int] = {}
        tool_calls: dict[int, dict[str, str]] = {}

        self.sse(
            "response.created",
            {
                "type": "response.created",
                "response": {
                    "id": response_id,
                    "object": "response",
                    "created_at": now(),
                    "status": "in_progress",
                    "model": model,
                    "output": [],
                },
            },
        )

        for raw_line in upstream:
            line = raw_line.decode("utf-8", errors="replace").strip()
            if not line or not line.startswith("data:"):
                continue
            data_text = line[5:].strip()
            if data_text == "[DONE]":
                break
            try:
                chunk = json.loads(data_text)
            except json.JSONDecodeError:
                continue
            choice = (chunk.get("choices") or [{}])[0]
            delta = choice.get("delta") or {}
            content = delta.get("content")
            if content:
                if not text_started:
                    text_started = True
                    next_output_index = 1
                    self.sse(
                        "response.output_item.added",
                        {
                            "type": "response.output_item.added",
                            "output_index": output_index,
                            "item": {
                                "type": "message",
                                "id": f"msg_{uuid.uuid4().hex}",
                                "status": "in_progress",
                                "role": "assistant",
                                "content": [],
                            },
                        },
                    )
                    self.sse(
                        "response.content_part.added",
                        {
                            "type": "response.content_part.added",
                            "output_index": output_index,
                            "content_index": 0,
                            "part": {"type": "output_text", "text": "", "annotations": []},
                        },
                    )
                text += content
                self.sse(
                    "response.output_text.delta",
                    {
                        "type": "response.output_text.delta",
                        "output_index": output_index,
                        "content_index": 0,
                        "delta": content,
                    },
                )

            for tool_call in delta.get("tool_calls") or []:
                idx = int(tool_call.get("index", 0))
                if idx not in tool_indexes:
                    tool_indexes[idx] = next_output_index
                    next_output_index += 1
                    tool_calls[idx] = {
                        "id": tool_call.get("id") or f"call_{uuid.uuid4().hex}",
                        "name": "",
                        "arguments": "",
                    }
                    self.sse(
                        "response.output_item.added",
                        {
                            "type": "response.output_item.added",
                            "output_index": tool_indexes[idx],
                            "item": {
                                "type": "function_call",
                                "id": f"fc_{uuid.uuid4().hex}",
                                "call_id": tool_calls[idx]["id"],
                                "name": "",
                                "arguments": "",
                                "status": "in_progress",
                            },
                        },
                    )
                function = tool_call.get("function") or {}
                if function.get("name"):
                    tool_calls[idx]["name"] = function["name"]
                if function.get("arguments"):
                    tool_calls[idx]["arguments"] += function["arguments"]
                    self.sse(
                        "response.function_call_arguments.delta",
                        {
                            "type": "response.function_call_arguments.delta",
                            "output_index": tool_indexes[idx],
                            "delta": function["arguments"],
                        },
                    )

        if text_started:
            self.sse(
                "response.output_text.done",
                {
                    "type": "response.output_text.done",
                    "output_index": 0,
                    "content_index": 0,
                    "text": text,
                },
            )
            self.sse(
                "response.output_item.done",
                {
                    "type": "response.output_item.done",
                    "output_index": 0,
                    "item": {
                        "type": "message",
                        "status": "completed",
                        "role": "assistant",
                        "content": [{"type": "output_text", "text": text, "annotations": []}],
                    },
                },
            )
        for idx, item in tool_calls.items():
            self.sse(
                "response.function_call_arguments.done",
                {
                    "type": "response.function_call_arguments.done",
                    "output_index": tool_indexes[idx],
                    "arguments": item["arguments"],
                },
            )
            self.sse(
                "response.output_item.done",
                {
                    "type": "response.output_item.done",
                    "output_index": tool_indexes[idx],
                    "item": {
                        "type": "function_call",
                        "call_id": item["id"],
                        "name": item["name"],
                        "arguments": item["arguments"],
                        "status": "completed",
                    },
                },
            )
        self.sse(
            "response.completed",
            {
                "type": "response.completed",
                "response": {
                    "id": response_id,
                    "object": "response",
                    "created_at": now(),
                    "status": "completed",
                    "model": model,
                    "output": [],
                    "usage": {"input_tokens": 0, "output_tokens": 0, "total_tokens": 0},
                },
            },
        )


def self_test() -> int:
    request = {
        "model": "deepseek-v4-pro",
        "instructions": "Be concise.",
        "input": [
            {"role": "user", "content": [{"type": "input_text", "text": "Find bugs."}]},
            {"type": "function_call_output", "call_id": "call_1", "output": "ok"},
        ],
        "tools": [
            {
                "type": "function",
                "name": "shell",
                "description": "Run shell",
                "parameters": {"type": "object", "properties": {"cmd": {"type": "string"}}},
            }
        ],
        "max_output_tokens": 100,
    }
    chat = responses_to_chat(request)
    assert chat["messages"][0]["role"] == "system"
    assert chat["messages"][1]["role"] == "user"
    assert chat["messages"][2]["role"] == "tool"
    assert chat["tools"][0]["function"]["name"] == "shell"
    assert chat["max_tokens"] == 100
    response = chat_to_response(
        {
            "model": "deepseek-v4-pro",
            "choices": [{"message": {"content": "Done"}}],
            "usage": {"prompt_tokens": 3, "completion_tokens": 2, "total_tokens": 5},
        },
        "deepseek-v4-pro",
    )
    assert response["output_text"] == "Done"
    assert response["usage"]["input_tokens"] == 3
    print("self-test passed")
    return 0


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Minimal Codex Responses proxy for DeepSeek.")
    parser.add_argument("--host", default=os.environ.get("DEEPSEEK_PROXY_HOST", DEFAULT_HOST))
    parser.add_argument("--port", type=int, default=int(os.environ.get("DEEPSEEK_PROXY_PORT", DEFAULT_PORT)))
    parser.add_argument("--upstream", default=os.environ.get("DEEPSEEK_BASE_URL", DEFAULT_UPSTREAM))
    parser.add_argument("--api-key-env", default="DEEPSEEK_API_KEY")
    parser.add_argument("--timeout", type=int, default=DEFAULT_TIMEOUT)
    parser.add_argument("--max-body-mb", type=int, default=128)
    parser.add_argument("--quiet", action="store_true")
    parser.add_argument("--self-test", action="store_true")
    return parser.parse_args(argv)


def main(argv: list[str]) -> int:
    args = parse_args(argv)
    if args.self_test:
        return self_test()
    if not os.environ.get(args.api_key_env):
        print(f"error: {args.api_key_env} is not set", file=sys.stderr)
        return 2
    server = ThreadingHTTPServer((args.host, args.port), ProxyHandler)
    server.upstream = args.upstream
    server.api_key_env = args.api_key_env
    server.timeout = args.timeout
    server.max_body_bytes = args.max_body_mb * 1024 * 1024
    server.quiet = args.quiet
    print(f"deepseek-responses-proxy listening on http://{args.host}:{args.port}/v1", flush=True)
    print(f"upstream: {args.upstream}/chat/completions", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nshutting down", file=sys.stderr)
        return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
